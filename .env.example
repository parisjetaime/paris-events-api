# Base de données Supabase (Session pooler)
DATABASE_URL=postgresql://postgres.XXXX:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# URL publique de l'API (utilisée dans le spec OpenAPI pour ChatGPT Actions)
API_BASE_URL=https://api.parisjetaime.com

# Score minimum pour afficher un événement (0-100)
API_MIN_SCORE=40

# Port interne du serveur
PORT=8000
