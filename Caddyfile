api.parisjetaime.com {
	reverse_proxy api:8000 {
		header_up Host localhost
	}

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		-Server
	}

	log {
		output stdout
		format json
	}
}

mcp.parisjetaime.com {
	# Permet d'accéder à MCP sur https://mcp.parisjetaime.com (sans /mcp)
	@root path /
	rewrite @root /mcp

	reverse_proxy mcp:8001

	header {
		X-Content-Type-Options nosniff
		-Server
	}

	log {
		output stdout
		format json
	}
}
